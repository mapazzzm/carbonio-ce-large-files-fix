[Unit]
Description=Carbonio Files chunked upload sidecar
After=network.target carbonio-files.service
Wants=carbonio-files.service

[Service]
Type=simple
User=zextras
Group=zextras
ExecStart=/usr/bin/python3 /usr/local/bin/carbonio-chunked-upload.py
Restart=on-failure
RestartSec=5
# Allow tcp bind on 127.0.0.1:5795
PrivateTmp=no
# Logs to journal
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
